{
  "run_name": "train_lb_challenger",
  "seed": 42,
  "data_dir": "data",
  "feature_set": "base_v2",
  "drop_identifiers": true,
  "use_target_encoding": true,
  "target_encode_cols": [
    "code_postal",
    "cp3",
    "modele_vehicule",
    "marque_modele"
  ],
  "target_encoding_smoothing": 20.0,
  "split": {
    "n_blocks_time": 5,
    "n_splits_group": 5,
    "group_col": "id_client",
    "split_names": [
      "primary_time",
      "secondary_group",
      "aux_blocked5"
    ]
  },
  "freq": {
    "engine": "catboost",
    "calibration": "none",
    "params": {
      "iterations": 2600,
      "learning_rate": 0.03,
      "depth": 7,
      "l2_leaf_reg": 6.0
    }
  },
  "sev": {
    "engine": "catboost",
    "family": "two_part_tweedie",
    "severity_mode": "weighted_tail",
    "tweedie_power": 1.2,
    "use_tail_mapper": true,
    "params": {
      "iterations": 4200,
      "learning_rate": 0.03,
      "depth": 8,
      "l2_leaf_reg": 6.0
    }
  },
  "prime": {
    "non_negative": true
  }
}

