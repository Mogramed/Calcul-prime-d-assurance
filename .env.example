INSURANCE_PRICING_LOG_LEVEL=INFO
INSURANCE_PRICING_LOG_JSON=true
INSURANCE_PRICING_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
INSURANCE_PRICING_ADMIN_EMAILS=admin@nova-assurances.fr
INSURANCE_PRICING_SESSION_TTL_HOURS=720
