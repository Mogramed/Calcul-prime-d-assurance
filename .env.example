INSURANCE_PRICING_RUN_ID=your_saved_run_id_here
INSURANCE_PRICING_DATABASE_URL=postgresql+psycopg://insurance_pricing:insurance_pricing@127.0.0.1:54329/insurance_pricing
# Hosted PostgreSQL example: paste the full provider connection string here (Neon, Supabase, etc.).
